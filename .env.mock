# ============================================================
# Local Development — Mock Mode
# No .NET backend required
# Copy this file to .env to run locally
# cp .env.mock .env  (Mac/Linux)
# copy .env.mock .env  (Windows)
# ============================================================

# ------------------------------------
# Mock Mode — disables real .NET calls
# ------------------------------------
MOCK_MODE=true

# ------------------------------------
# .NET Backend — not used in mock mode
# ------------------------------------
BACKEND_BASE_URL=http://localhost:5000
BACKEND_API_KEY=not-needed-in-mock-mode

# ------------------------------------
# App
# ------------------------------------
ALLOWED_ORIGINS=http://localhost:3000
PRODUCTION=false
APP_VERSION=1.0.0

# ------------------------------------
# Database
# ------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/realestate

# ------------------------------------
# Vector DB (ChromaDB)
# ------------------------------------
CHROMA_PATH=./chroma_db
SIMILARITY_THRESHOLD=0.7
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ------------------------------------
# Ollama (local LLM — optional in mock mode)
# ------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------
# Groq — required (real AI, mock data)
# Get your key at: https://console.groq.com
# ------------------------------------
GROQ_API_KEY=gsk_your_key_here
MODEL_NAME=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ------------------------------------
# OpenAI — optional, leave blank if not using
# ------------------------------------
OPENAI_API_KEY=

# ------------------------------------
# Agent / Tool Calling
# ------------------------------------
AGENT_TOOL_CALL_MODEL=llama-3.3-70b-versatile
AGENT_TIMEOUT_SECONDS=30

# ------------------------------------
# Logging
# ------------------------------------
LOG_LEVEL=INFO
