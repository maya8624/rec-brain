# --- Python Virtual Environments ---
# It is best practice to keep your venv out of version control.
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# --- Python Bytecode and Caches ---
# These are generated automatically and should not be committed.
__pycache__/
*.py[cod]
*$py.class

# --- Environment Variables (CRITICAL) ---
# Never commit your .env files containing secrets.
.env
.env.development
.env.local
.env.production
.env.*

# --- IDE/Editor Settings ---
# Local settings specific to your machine or editor.
.vscode/
.idea/
*.swp
*.swo

# --- Build/Distribution Folders ---
# Folders generated when packaging your application.
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Testing and Coverage ---
# Temporary files generated by testing frameworks like pytest or nose.
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# --- Database/Logs ---
# Local database files and application logs.
*.db
*.log
*.sqlite3

# --- Documentation ---
docs/_build/


.claude/